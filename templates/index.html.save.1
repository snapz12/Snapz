<script>
// Master Global Variables
let mode = "post";
let facing = "environment"; // 'environment' matlab Back Camera, 'user' matlab Front Camera
let stream = null;
let selectedFile = null;
let mediaRecorder;
let chunks = [];
let recording = false;

// Camera page open karne ke liye
document.getElementById("createBtn").onclick = function() {
    let camera = document.getElementById("cameraPage");
    camera.style.display = "block";
    document.body.style.overflow = "hidden";
    
    setMode("post");
    startCamera();
};

// Mode switch karne ke liye (Post, Story, Reels)
function setMode(value) {
    mode = value;
    document.getElementById("type").value = value;
    console.log("Active Mode:", mode);

    document.querySelectorAll(".mode span").forEach(x => x.style.color = "gray");
    let activeOption = document.getElementById("opt-" + value);
    if (activeOption) {
        activeOption.style.color = "white";
        activeOption.style.fontWeight = "bold";
    }

    resetMediaView();
}

// 🔄 Camera Start karne ka dynamic function (Front/Back handle ke saath)
async function startCamera() {
    try {
        // Pehle se chal rahe camera tracks ko achhe se stop karo taaki switch smoothly ho
        if (stream) {
            stream.getTracks().forEach(t => t.stop());
        }

        stream = await navigator.mediaDevices.getUserMedia({
            video: { facingMode: facing },
            audio: true
        });

        let camVideo = document.getElementById("cam");
        camVideo.srcObject = stream;
        camVideo.style.display = "block";
    } catch (e) {
        alert("Camera permission allow kijiye!");
    }
}

// 🔄 Front aur Back camera toggle switch handler
function switchCamera() {
    facing = (facing === "environment") ? "user" : "environment";
    console.log("Switching camera to:", facing);
    startCamera();
}

// Camera close handler
function closeCamera() {
    if (stream) {
        stream.getTracks().forEach(t => t.stop());
        stream = null;
    }
    document.getElementById("cameraPage").style.display = "none";
    document.body.style.overflow = "auto";
    resetMediaView();
}

// Preview Reset Function
function resetMediaView() {
    let video = document.getElementById("cam");
    let previewCont = document.getElementById("previewContainer");
    let previewImg = document.getElementById("preview");
    let previewVid = document.getElementById("previewVideo");

    if (video) video.style.display = "block";
    if (previewCont) previewCont.style.display = "none";
    if (previewImg) previewImg.style.display = "none";
    if (previewVid) {
        previewVid.pause();
        previewVid.style.display = "none";
    }
    selectedFile = null;
    document.getElementById("timer").innerHTML = "00:00";
    recording = false;
}

// Next dabane par caption page par le jane ke liye
function nextCaption() {
    if (!selectedFile) {
        alert("Pehle photo ya video click kijiye ya Gallery se select kijiye!");
        return;
    }

    if (stream) {
        stream.getTracks().forEach(t => t.stop());
        stream = null;
    }

    document.getElementById("cameraPage").style.display = "none";
    document.getElementById("captionPage").style.display = "block";
}

// Photo click ya Video Record trigger capture button
function capture() {
    if (mode === "reel") {
        if (recording) {
            mediaRecorder.stop();
            recording = false;
        } else {
            startRecording();
            recording = true;
        }
        return;
    }

    // Photo Capture Logic (Post & Story)
    let video = document.getElementById("cam");
    let canvas = document.createElement("canvas");
    canvas.width = video.videoWidth;
    canvas.height = video.videoHeight;

    let ctx = canvas.getContext("2d");
    ctx.drawImage(video, 0, 0, canvas.width, canvas.height);

    canvas.toBlob(function(blob) {
        selectedFile = new File([blob], "photo.jpg", { type: "image/jpeg" });
        
        let previewImg = document.getElementById("preview");
        let previewCont = document.getElementById("previewContainer");
        
        previewImg.src = URL.createObjectURL(blob);
        video.style.display = "none";
        previewCont.style.display = "block";
        previewImg.style.display = "block";
    }, "image/jpeg");
}

// 🖼️ Gallery open karne ke liye click trigger
function galleryOpen() {
    document.getElementById("gallery").click();
}

// 🖼️ Gallery se photo/video select hone ke baad ka logic
function gallerySelect() {
    let file = document.getElementById("gallery").files[0];
    if (!file) return;

    selectedFile = file; // Select ki hui file variable me save ho gayi
    
    let video = document.getElementById("cam");
    let previewCont = document.getElementById("previewContainer");
    let previewImg = document.getElementById("preview");
    let previewVid = document.getElementById("previewVideo");

    video.style.display = "none";
    previewCont.style.display = "block";

    // Agar user ne video select kiya hai
    if (file.type.startsWith("video/")) {
        previewImg.style.display = "none";
        previewVid.src = URL.createObjectURL(file);
        previewVid.style.display = "block";
        previewVid.play();
        console.log("Gallery se Video select hua.");
    } else {
        // Agar user ne photo select ki hai
        previewVid.style.display = "none";
        previewImg.src = URL.createObjectURL(file);
        previewImg.style.display = "block";
        console.log("Gallery se Image select hui.");
    }
}

// Reels ke liye recording module
function startRecording() {
    let video = document.getElementById("cam");
    let camStream = video.srcObject;

    if (!camStream) {
        alert("Camera taiyar nahi hai");
        return;
    }

    chunks = [];
    mediaRecorder = new MediaRecorder(camStream, { mimeType: 'video/webm' });

    mediaRecorder.ondataavailable = function(e) {
        if (e.data.size > 0) chunks.push(e.data);
    };

    mediaRecorder.onstop = function() {
        let blob = new Blob(chunks, { type: "video/webm" });
        selectedFile = new File([blob], "reel.webm", { type: "video/webm" });

        let previewCont = document.getElementById("previewContainer");
        let previewVid = document.getElementById("previewVideo");

        video.style.display = "none";
        previewCont.style.display = "block";
        previewVid.src = URL.createObjectURL(blob);
        previewVid.style.display = "block";
        previewVid.play();

        document.getElementById("timer").innerHTML = "00:00";
        alert("Video recorded from camera!");
    };

    mediaRecorder.start();
    document.getElementById("timer").innerHTML = "🔴 REC";

    // 15 seconds automatic record stopper
    setTimeout(() => {
        if (mediaRecorder && mediaRecorder.state === "recording") {
            mediaRecorder.stop();
            recording = false;
        }
    }, 15000);
}

// Server par final fetch request post data send karne ke liye
function finalUpload() {
    if (!selectedFile) {
        alert("Koi file select nahi hui hai.");
        return;
    }

    let formData = new FormData();
    formData.append("file", selectedFile);
    formData.append("caption", document.getElementById("caption").value.trim());
    formData.append("type", mode); 

    fetch("/upload", {
        method: "POST",
        body: formData
    })
    .then(res => {
        if (res.ok) {
            alert("Uploaded Successfully!");
            window.location.href = "/"; 
        } else {
            alert("Upload Failed!");
        }
    })
    .catch(err => {
        console.error(err);
        alert("Network Error!");
    });
}
</script>


