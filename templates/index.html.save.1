        </button>

    </div>


    <img id="storyImage"
    src=""
    class="story-image">


    <div class="story-buttons">

        <button onclick="prevStory()">
            ◀
        </button>


        <button onclick="nextStory()">
            ▶
        </button>

    </div>


</div>


<script>
let storyList = {{ stories|tojson if stories else '[]' }};
let currentStory = 0;
let timer;
let barInterval;

function openStory(image, user) {
    // Path match karne ke liye filename extract karna
    let cleanFilename = image.replace("/static/uploads/", "").replace("/uploads/", "");
    currentStory = storyList.findIndex(x => x[1] == cleanFilename);
    
    if(currentStory === -1) currentStory = 0;
    showStory();
}

function showStory() {
    if (!storyList || storyList.length === 0 || currentStory >= storyList.length) {
        closeStory();
        return;
    }

    let s = storyList[currentStory];
    document.getElementById("storyImage").src = "/static/uploads/" + s[1];
    document.getElementById("storyUser").innerHTML = s[0];
    document.getElementById("storyViewer").style.display = "block";

    // Purane intervals clear karein
    clearInterval(barInterval);
    
    let width = 0;
    let progressBar = document.getElementById("progress");
    
    barInterval = setInterval(() => {
        width += 1;
        progressBar.style.width = width + "%";
        if (width >= 100) {
            clearInterval(barInterval);
            nextStory();
        }
    }, 50); // 5 seconds total story time (50ms * 100 = 5000ms)
}

function nextStory() {
    currentStory++;
    showStory();
}

function prevStory() {
    if (currentStory > 0) {
        currentStory--;
        showStory();
    }
}

function closeStory() {
    document.getElementById("storyViewer").style.display = "none";
    clearInterval(barInterval);
}

function openCamera() {
    alert("Camera trigger open! Ya fir naya story upload form open karein.");
}
</script>

{% for post in posts %}
<div class="post">
    <div class="post-header">
        <div class="user-info">
            <img src="/static/profile.jpg" class="profile-pic">
            <h3 style="margin: 0; color: white; font-size: 16px;">{{post[0]}}</h3>
        </div>
        <button id="follow-btn-{{loop.index}}" class="follow-btn" onclick="toggleFollow(this)">Follow</button>
    </div>

    <img src="/static/uploads/{{post[1]}}" class="post-img">

    <div class="action-bar">
        <button onclick="toggleLike(this)" class="action-btn">
            <span class="heart-icon">🤍</span> <span class="like-count">0</span>
        </button>
        <button onclick="toggleCommentBox('comment-box-{{loop.index}}')" 
                style="background:none; border:none; color:white; font-size: 24px; position: absolute; left: 50%; transform: translateX(-50%);">
            💬
        </button>
        <button onclick="openShare()" class="action-btn" style="margin-left: auto;">📥</button>
    </div>

    <div id="comment-box-{{loop.index}}" class="comment-box" style="display: none;">
        <input id="comment-input-{{loop.index}}" class="comment-input" placeholder="Add comment...">
        <button onclick="addComment('{{loop.index}}')" style="background: #0095f6; color: white; border: none; padding: 5px 10px;">Post</button>
        <div id="comments-list-{{loop.index}}" style="margin-top: 5px; color: white; font-size: 14px;"></div>
    </div>
</div>
{% endfor %}


<script>
// Like Logic (With Count)
function toggleLike(btn) {
    let heart = btn.querySelector(".heart-icon");
    let countSpan = btn.querySelector(".like-count");
    let count = parseInt(countSpan.innerText);

    if (btn.classList.contains("active")) {
        btn.classList.remove("active");
        heart.innerText = "🤍";
        countSpan.innerText = count - 1;
    } else {
        btn.classList.add("active");
        heart.innerText = "❤️";
        countSpan.innerText = count + 1;
    }
}

// Toggle Comment Box
function toggleCommentBox(id) {
    let box = document.getElementById(id);
    box.style.display = (box.style.display === "none" || box.style.display === "") ? "block" : "none";
}

// Add Comment
function addComment(index) {
    let input = document.getElementById('comment-input-' + index);
    let list = document.getElementById('comments-list-' + index);
    if (input.value.trim() !== "") {
        let p = document.createElement('p');
        p.innerText = input.value;
        list.appendChild(p);
        input.value = "";
    }
}

// Share Logic (Ensure shareBox ID exists in HTML)
function openShare() {
    let box = document.getElementById('shareBox');
    if (box) box.style.display = "block";
}

function closeShare() {
    document.getElementById('shareBox').style.display = "none";
}

// Follow Logic
function toggleFollow(btn) {
    btn.innerText = "Following";
    btn.style.background = "#333";
    btn.style.color = "#888";
}
</script>



</body>
</html>


