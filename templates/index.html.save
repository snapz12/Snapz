<div id="createScreen" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:#000; z-index:9999; width: 100vw; height: 100vh; overflow: hidden;">
    
    <button onclick="document.getElementById('createScreen').style.display='none'; if(stream){stream.getTracks().forEach(t=>t.stop());}" style="position:absolute; left:20px; top:20px; background:rgba(0,0,0,0.6); color:white; border:none; border-radius:50%; width:42px; height:42px; font-size:22px; cursor:pointer; z-index:10010; display:flex; align-items:center; justify-content:center;">✕</button>
    
    <button id="nextBtn" onclick="handleDirectUpload()" style="display:none; position:absolute; right:20px; top:20px; background: #0095f6; color: white; border: none; padding: 10px 22px; border-radius: 20px; font-weight: bold; font-size: 15px; cursor: pointer; z-index:10010;">NEXT</button>

    <video id="camera" style="width:100vw; height:100vh; object-fit:cover; position:absolute; top:0; left:0; z-index:9998;" autoplay playsinline></video>
    
    <img id="preview" style="width:100vw !important; height:100vh !important; object-fit:cover !important; position:absolute; top:0 !important; left:0 !important; display:none; z-index:10000; margin:0; padding:0;">

    <div id="cameraControls" style="position:absolute; bottom:25px !important; left:0; width:100%; padding-bottom:10px; background:linear-gradient(transparent, rgba(0,0,0,0.85)); z-index:10005; display:flex; flex-direction:column; align-items:center; gap:15px;">
