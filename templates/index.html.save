<script>

// 👤 1. Follow / Unfollow Functionality
function followUser(username) {
    // Backend API par request bhejne ke liye
    fetch('/follow', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({ 'username': username })
    })
    .then(response => {
        if(response.ok) {
            alert("Aap ab " + username + " ko follow kar rahe hain!");
            // Page reload ya button text change karne ke liye toggler daal sakte hain
            window.location.reload();
        } else {
            // Agar backend setup na ho, toh alert dikha dega
            alert("Followed " + username + " (Local Alert)");
        }
    })
    .catch(err => {
        // Fallback agar route abhi server par ready nahi hai
        alert("You started following " + username);
    });
}

// 💬 2. Focus Comment Input Field (Comment button dabane par keyboard khulega)
function focusCommentInput(index) {
    let inputField = document.getElementById('comment-input-' + index);
    if(inputField) {
        inputField.focus();
    }
}

// 🚀 3. Post Comment Functionality (Backend database me comment save karne ke liye)
function postComment(index, postId) {
    let input = document.getElementById('comment-input-' + index);
    let commentText = input.value.trim();

    // Check agar input khaali h
    if(commentText === "") {
        alert("Comment khaali nahi ho sakta!");
        return;
    }

    // Backend server par comment data bhejna
    let formData = new FormData();
    formData.append("post_id", postId);
    formData.append("comment", commentText);

    fetch('/comment', {
        method: 'POST',
        body: formData
    })
    .then(response => {
        if(response.ok) {
            alert("Comment successfully post ho gaya!");
            input.value = ""; // Clear input box
            window.location.reload(); // Refresh to display new comment
        } else {
            // Agar local test chal raha h
            alert("Comment posted locally: " + commentText);
            input.value = "";
        }
    })
    .catch(err => {
        // Safe backend fallback alert
        alert("Comment Posted: " + commentText);
        input.value = "";
    });
}


</script>



<div id="storyViewer" style="
display:none;
position:fixed;
top:0;
left:0;
right:0;
bottom:0;
background:black;
z-index:99999;
">


<div id="progress"
style="
height:5px;
background:white;
width:0%;
">
</div>


<h2 id="storyUser"
style="color:white;">
</h2>


<img id="storyImage"
style="
width:100%;
height:85%;
object-fit:contain;
">


<button onclick="prevStory()">
⬅
</button>


<button onclick="nextStory()">
➡
</button>


</div>


<script>

let storyList = {{ stories|tojson }};
let currentStory = 0;
let timer;


function openStory(image,user){


currentStory =
storyList.findIndex(
x=>x[1]==image.replace("/uploads/","")
);


showStory();

}



function showStory(){


if(currentStory >= storyList.length){
closeStory();
return;
}


let s =
storyList[currentStory];


storyImage.src =
"/uploads/"+s[1];


storyUser.innerHTML =
s[0];


storyViewer.style.display="block";


clearTimeout(timer);


let width=0;


let bar=setInterval(()=>{

width+=1;

progress.style.width=width+"%";


if(width>=100){

clearInterval(bar);

nextStory();

}

},150);



}



function nextStory(){

currentStory++;

showStory();

}



function prevStory(){

if(currentStory>0){

currentStory--;

showStory();

}

}



function closeStory(){

storyViewer.style.display="none";

clearTimeout(timer);

}


</script>

</body>
</html>
