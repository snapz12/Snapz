            <span id="opt-reel" onclick="setType('reel')" style="cursor:pointer; text-shadow: 0px 2px 6px rgba(0,0,0,0.9);">Reels</span>
        </div>
        <div style="display:flex; justify-content:space-between; align-items:center; width:100%; padding:0 45px; box-sizing:border-box;">
            <div onclick="openGallery()" style="width:50px; height:50px; border-radius:10px; border:2px solid white; overflow:hidden; background:rgba(255,255,255,0.2); cursor:pointer; display:flex; align-items:center; justify-content:center; backdrop-filter: blur(5px);"><span style="font-size:26px;">🖼️</span></div>
            <div id="shutterBtn" onclick="capturePhoto()" style="width:80px; height:80px; border-radius:50%; border:5px solid #fff; background:transparent; display:flex; align-items:center; justify-content:center; cursor:pointer;"><div style="width:62px; height:62px; border-radius:50%; background:#fff;"></div></div>
            <div style="width:50px;"></div> </div>
    </div>
    <input type="file" id="gallery" accept="image/*" style="display:none" onchange="galleryPreview()">
</div>

