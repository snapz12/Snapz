<textarea id="caption"
placeholder="Write caption"
style="
width:100%;
height:120px;
">
</textarea>


<br><br>


<button onclick="finalUpload()">
Upload
</button>


</div>







<script>

let mode="post";

let facing="environment";

let stream;

let selectedFile;


let mediaRecorder;
let chunks=[];
let recording=false;

function setMode(x){

mode=x;


if(mode=="reel"){

document.getElementById("captureBtn")
.innerHTML="🔴";

}
else{

document.getElementById("captureBtn")
.innerHTML="⚪";

}


}


function openCamera(){

alert("button chal raha hai");


let camera =
document.getElementById("cameraPage");


camera.style.display="block";


}



async function startCamera(){


if(stream){

stream.getTracks()
.forEach(t=>t.stop());

}



stream =
await navigator.mediaDevices.getUserMedia({

video:{
facingMode:facing
}

});



document.getElementById("cam")
.srcObject=stream;


}






function switchCamera(){


if(facing=="environment"){

facing="user";

}
else{

facing="environment";

}



startCamera();


}





function capture(){


if(mode=="reel"){

startRecording();

return;

}


// PHOTO (Post / Story)

let video =
document.getElementById("cam");


let canvas =
document.createElement("canvas");


canvas.width =
video.videoWidth;


canvas.height =
video.videoHeight;



canvas
.getContext("2d")
.drawImage(
video,
0,
0,
canvas.width,
canvas.height
);



canvas.toBlob(function(blob){



selectedFile =
new File(
[blob],
"photo.jpg",
{
type:"image/jpeg"
}
);



let preview =
document.getElementById("preview");



preview.src =
URL.createObjectURL(blob);



video.style.display="none";


preview.style.display="block";


// timer hide

document
.getElementById("timer")
.style.display="none";



}, "image/jpeg");



}





// Gallery open

function galleryOpen(){


document
.getElementById("gallery")
.click();


}







// Gallery select


function gallerySelect(){


let file =
document
.getElementById("gallery")
.files[0];



if(!file){

return;

}



selectedFile=file;



document.getElementById("preview")
.src =
URL.createObjectURL(file);



document.getElementById("cam")
.style.display="none";



document.getElementById("preview")
.style.display="block";



}









function closeCamera(){


if(stream){

stream.getTracks()
.forEach(t=>t.stop());

}



document.getElementById("cameraPage")
.style.display="none";



document.body.style.overflow="auto";


}




function nextCaption(){


if(!selectedFile){

alert("Pehle photo/video lo");

return;

}


document.getElementById("cameraPage")
.style.display="none";


document.getElementById("captionPage")
.style.display="block";


}









document
.getElementById("createBtn")
.onclick = function(){

document
.getElementById("cameraPage")
.style.display="block";

document.body.style.overflow="hidden";

startCamera();

};






function finalUpload(){

let formData = new FormData();

formData.append("file", selectedFile);

formData.append(
"caption",
document.getElementById("caption").value
);

formData.append(
"type",
mode
);


fetch("/upload",{
method:"POST",
body:formData
})
.then(res=>{

if(res.redirected){
window.location.href="/";
}

});

}



async function startRecording(){

let video =
document.getElementById("cam");


let stream =
video.srcObject;


chunks=[];


mediaRecorder =
new MediaRecorder(stream);


let seconds=0;


document.getElementById("timer")
.innerHTML="00:00";


let timer=setInterval(()=>{


seconds++;


let m =
String(Math.floor(seconds/60))
.padStart(2,"0");


let s =
String(seconds%60)
.padStart(2,"0");


document.getElementById("timer")
.innerHTML =
m+":"+s;



},1000);



mediaRecorder.ondataavailable=function(e){

chunks.push(e.data);

};



mediaRecorder.onstop=function(){


clearInterval(timer);



let blob =
new Blob(
chunks,
{
type:"video/webm"
}
);



selectedFile =
new File(
[blob],
"reel.webm",
{
type:"video/webm"
}
);



let preview =
document.getElementById("preview");



preview.src =
URL.createObjectURL(blob);



video.style.display="none";


preview.style.display="block";


document.getElementById("timer")
.style.display="none";


};



mediaRecorder.start();

recording=true;



setTimeout(()=>{


if(recording){

mediaRecorder.stop();

recording=false;

}


},15000);


}


</script>





    {% for story in stories %}
